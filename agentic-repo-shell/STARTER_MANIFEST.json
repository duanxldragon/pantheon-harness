{
  "name": "agentic-repo-shell",
  "purpose": "Repo-local shell for new repositories that adopt the agentic method",
  "requires": [
    "agentic-method-kit"
  ],
  "includes": [
    ".agents",
    ".github",
    ".harness",
    "docs/harness",
    "openspec",
    "scripts/harness"
  ],
  "excludes": [
    "historical task packets",
    "historical evidence",
    "historical reviews",
    "repo-specific Codex local skills"
  ],
  "optionalOverlays": [
    "pantheon-overlay"
  ]
}
