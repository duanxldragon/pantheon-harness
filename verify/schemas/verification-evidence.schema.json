{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Portable Verification Evidence",
  "type": "object",
  "required": ["taskId", "repo", "agent", "commands", "methodReadiness", "linkage", "knownGaps"],
  "properties": {
    "taskId": { "type": "string" },
    "repo": { "type": "string" },
    "agent": {
      "type": "object",
      "required": ["tool"],
      "properties": {
        "tool": { "type": "string" },
        "adapter": { "type": "string" }
      }
    },
    "commands": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["command", "cwd", "status"],
        "properties": {
          "command": { "type": "string" },
          "cwd": { "type": "string" },
          "status": { "type": "string" },
          "durationMs": { "type": "number" },
          "notes": { "type": "string" }
        }
      }
    },
    "methodReadiness": {
      "type": "object",
      "required": ["ownerLayer", "ratchetDecision", "deferredCodeIssues"],
      "properties": {
        "ownerLayer": {
          "type": "string",
          "enum": [
            "portable-method",
            "consumer-template",
            "consumer-repository",
            "agent-adapter",
            "no-action"
          ]
        },
        "ratchetDecision": {
          "type": "string",
          "enum": [
            "no-repeat-observed",
            "guide-updated",
            "sensor-added",
            "gate-updated",
            "template-updated",
            "adapter-updated",
            "registry-only"
          ]
        },
        "deferredCodeIssues": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "graphChecks": {
      "type": "object",
      "properties": {
        "usedCodeGraph": { "type": "boolean" },
        "affectedSubgraph": {
          "oneOf": [
            { "type": "string" },
            {
              "type": "array",
              "items": { "type": "string" }
            }
          ]
        },
        "checks": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["cycle", "hub", "call-depth", "sensitive-flow"]
          }
        },
        "findings": {
          "type": "array",
          "items": { "type": "string" }
        },
        "notes": { "type": "string" }
      }
    },
    "sessionEconomics": {
      "type": "object",
      "properties": {
        "responseMode": {
          "type": "string",
          "enum": ["terse", "standard", "detailed"]
        },
        "costSensitivity": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "inputTokens": { "type": "number" },
        "outputTokens": { "type": "number" },
        "cacheReadTokens": { "type": "number" },
        "cacheWriteTokens": { "type": "number" },
        "estimatedCostUsd": { "type": "number" },
        "retryCount": { "type": "number" },
        "delegationCount": { "type": "number" },
        "notes": { "type": "string" }
      }
    },
    "browserEvidence": {
      "type": "array",
      "items": { "type": "object" }
    },
    "runtimeSensitive": { "type": "boolean" },
    "runtimeLogs": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "array",
          "items": { "type": "string" }
        }
      ]
    },
    "runtimeMetrics": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "array",
          "items": { "type": "string" }
        }
      ]
    },
    "runtimeTraces": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "array",
          "items": { "type": "string" }
        }
      ]
    },
    "runtimePerformance": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "array",
          "items": { "type": "string" }
        }
      ]
    },
    "runtimeGap": { "type": "string" },
    "linkage": {
      "type": "object",
      "required": ["taskPacket", "evidenceDir", "reviewFile", "changeRef", "planRefs"],
      "properties": {
        "taskPacket": { "type": "string" },
        "evidenceDir": { "type": "string" },
        "reviewFile": { "type": "string" },
        "changeRef": { "type": "string" },
        "planRefs": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "knownGaps": {
      "type": "array",
      "items": { "type": "string" }
    },
    "completedAt": { "type": "string" }
  }
}
